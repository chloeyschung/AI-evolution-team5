{
  "name": "briefly-web-dashboard",
  "version": "1.0.0",
  "description": "Web dashboard for Briefly - Manage your Knowledge Library",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "PW_HEADED=true playwright test",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test:e2e:circle1": "playwright test tests/e2e/circle1.frontend-frontend.spec.ts",
    "test:e2e:circle2": "playwright test -c playwright.integration.config.ts tests/e2e/circle2.backend-frontend.spec.ts",
    "test:e2e:circle3": "playwright test -c playwright.integration.config.ts tests/e2e/circle3.db-backend-frontend.spec.ts",
    "test:e2e:circles": "npm run test:e2e:circle1 && npm run test:e2e:circle2 && npm run test:e2e:circle3"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "@playwright/test": "^1.40.0"
  }
}
