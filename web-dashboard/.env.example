# Google OAuth Client ID
# Create a project at https://console.cloud.google.com/ and add OAuth credentials
# Authorized redirect URIs: http://localhost:3001/oauth-callback
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API URL
# Local dev recommendation: keep /api so Vite proxy forwards to backend (avoids CORS)
# For direct backend calls (staging/prod), set absolute URL like https://api.example.com
VITE_API_BASE_URL=/api
