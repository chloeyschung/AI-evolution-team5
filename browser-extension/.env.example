# Briefly Browser Extension Configuration
# Copy this file to .env and fill in your values

# Google OAuth Client ID
# Get this from: https://console.cloud.google.com/apis/credentials
# The application type should be "Web application"
# Authorized redirect URIs should include: <extension-id>.chromium.app/login/login.html
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend API URL used by extension auth/save requests.
# Example: https://api.briefly.app
VITE_API_BASE_URL=http://localhost:8000

# Show API base URL input in popup (set true only for local debugging).
VITE_SHOW_API_URL_SETTING=false
